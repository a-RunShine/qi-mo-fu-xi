digraph 第七章 {
    rankdir=LR;
    bgcolor="#FAFBFC";
    node [shape=box, style="rounded,filled", fontname="STHeiti", fontsize=11];
    edge [color="#5B6770", penwidth=1.2];
    splines=ortho;
    nodesep=0.3;
    ranksep=0.6;

    // ===== 根节点 =====
    root [label="第七章\n数据库设计的步骤", fillcolor="#1A5276", fontcolor=white, fontsize=15, shape=box, style="filled,rounded", width=2.2, height=1.2];

    // ===== 核心矛盾 =====
    core [label="根本矛盾", fillcolor="#2E86C1", fontcolor=white, fontsize=12];
    core_detail [label="模糊口头需求\n→ 能跑的真实数据库\n6 步流水线填平鸿沟", fillcolor="#D6EAF8", fontcolor="#1A5276", fontsize=10];
    root -> core;
    core -> core_detail;

    // ===== 一级分支：需求分析 =====
    req [label="1 需求分析\n客户调研", fillcolor="#1ABC9C", fontcolor=white, fontsize=12];
    root -> req;
    r1 [label="调查机构\n熟悉业务", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    r2 [label="明确用户需求\n确定系统边界", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    r3 [label="产出:数据字典\n数据户口本", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    r4 [label="产出:需求规格说明书\n客户需求清单", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    req -> r1;
    req -> r2;
    req -> r3;
    req -> r4;

    // ===== 一级分支：概念结构设计 =====
    concept [label="2 概念结构设计\n画草图", fillcolor="#27AE60", fontcolor=white, fontsize=12];
    root -> concept;
    c1 [label="抽象为概念模型", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    c2 [label="绘制E-R图\n实体/属性/联系", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    c3 [label="产出:E-R图\n通用草图(中间翻译)", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    concept -> c1;
    concept -> c2;
    concept -> c3;

    // ===== 一级分支：逻辑+物理结构设计 =====
    struct [label="3+4 逻辑/物理\n结构设计\n(对应第一章3层模型)", fillcolor="#8E44AD", fontcolor=white, fontsize=12];
    root -> struct;
    // 逻辑
    logic [label="3 逻辑结构设计\n画施工图", fillcolor="#E8DAEF", fontcolor="#6C3483", fontsize=11];
    l1 [label="E-R图→关系模型", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    l2 [label="规范化优化(第2章)", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    l3 [label="产出:关系模式\n含数据库模式+外模式", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    logic -> l1;
    logic -> l2;
    logic -> l3;
    // 物理
    physic [label="4 物理结构设计\n具体施工方案", fillcolor="#E8DAEF", fontcolor="#6C3483", fontsize=11];
    p1 [label="选择存取方法", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    p2 [label="设计关系", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    p3 [label="设计索引等\n物理存储结构", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    physic -> p1;
    physic -> p2;
    physic -> p3;
    struct -> logic;
    struct -> physic;

    // ===== 一级分支：实施+维护 =====
    run [label="5+6 实施+维护\n建造+物业", fillcolor="#D35400", fontcolor=white, fontsize=12];
    root -> run;
    // 实施
    impl [label="5 数据库实施", fillcolor="#FDEBD0", fontcolor="#A04000", fontsize=11];
    i1 [label="建库(SQL DDL)", fillcolor="#FDEBD0", fontcolor="#A04000"];
    i2 [label="试运行(易漏)", fillcolor="#FDEBD0", fontcolor="#A04000"];
    i3 [label="装入数据", fillcolor="#FDEBD0", fontcolor="#A04000"];
    impl -> i1;
    impl -> i2;
    impl -> i3;
    // 维护
    maint [label="6 运行维护\n占生命期90%", fillcolor="#FDEBD0", fontcolor="#A04000", fontsize=11];
    m1 [label="安全性→第4章", fillcolor="#FDEBD0", fontcolor="#A04000"];
    m2 [label="完整性→第5章", fillcolor="#FDEBD0", fontcolor="#A04000"];
    m3 [label="转储恢复→第10/11章", fillcolor="#FDEBD0", fontcolor="#A04000"];
    m4 [label="性能监督分析", fillcolor="#FDEBD0", fontcolor="#A04000"];
    m5 [label="增加新功能", fillcolor="#FDEBD0", fontcolor="#A04000"];
    m6 [label="发现/修改错误", fillcolor="#FDEBD0", fontcolor="#A04000"];
    maint -> m1;
    maint -> m2;
    maint -> m3;
    maint -> m4;
    maint -> m5;
    maint -> m6;
    run -> impl;
    run -> maint;
}
