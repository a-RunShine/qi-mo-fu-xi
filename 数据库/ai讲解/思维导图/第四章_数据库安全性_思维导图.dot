digraph 第四章 {
    rankdir=LR;
    bgcolor="#FAFBFC";
    node [shape=box, style="rounded,filled", fontname="STHeiti", fontsize=11];
    edge [color="#5B6770", penwidth=1.2];
    splines=ortho;
    nodesep=0.3;
    ranksep=0.6;

    // ===== 根节点 =====
    root [label="第四章\n数据库安全性", fillcolor="#1A5276", fontcolor=white, fontsize=15, shape=box, style="filled,rounded", width=2.2, height=1.2];

    // ===== 核心矛盾 =====
    core [label="核心矛盾", fillcolor="#2E86C1", fontcolor=white, fontsize=12];
    core_detail [label="让该用的人能用\n不该用的人用不了", fillcolor="#D6EAF8", fontcolor="#1A5276", fontsize=10];
    root -> core;
    core -> core_detail;

    // ===== 一级分支：不安全因素 =====
    unsafe [label="不安全因素", fillcolor="#E74C3C", fontcolor=white, fontsize=12];
    root -> unsafe;
    u1 [label="非授权用户\n恶意存取和破坏", fillcolor="#FADBD8", fontcolor="#922B21"];
    u2 [label="重要数据泄露", fillcolor="#FADBD8", fontcolor="#922B21"];
    u3 [label="安全环境脆弱", fillcolor="#FADBD8", fontcolor="#922B21"];
    unsafe -> u1 -> u2 -> u3 [arrowhead=none];

    // ===== 一级分支：安全性控制手段 =====
    control [label="安全性控制手段", fillcolor="#27AE60", fontcolor=white, fontsize=12];
    root -> control;
    c1 [label="身份鉴别\n（进门刷脸）", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    c2 [label="存取控制 ★核心\n（借钥匙/收钥匙）", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    c3 [label="视图机制\n（墙上开窗）", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    c4 [label="审计\n（装摄像头）", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    c5 [label="数据加密\n（偷到也是天书）", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    control -> c1;
    control -> c2;
    control -> c3;
    control -> c4;
    control -> c5;

    // ===== 一级分支：GRANT =====
    grant [label="GRANT 授予权限", fillcolor="#8E44AD", fontcolor=white, fontsize=12];
    root -> grant;
    g1 [label="GRANT 权限 ON 对象\nTO 用户名", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    g2 [label="WITH GRANT OPTION\n可转授给他人", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    g3 [label="禁止循环授权\n不能往回传给授权者", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    grant -> g1;
    grant -> g2;
    grant -> g3;

    // ===== 一级分支：REVOKE =====
    revoke [label="REVOKE 收回权限", fillcolor="#D35400", fontcolor=white, fontsize=12];
    root -> revoke;
    r1 [label="REVOKE 权限 ON 对象\nFROM 用户名", fillcolor="#FDEBD0", fontcolor="#A04000"];
    r2 [label="CASCADE\n级联回收（连坐制）", fillcolor="#FDEBD0", fontcolor="#A04000"];
    r3 [label="RESTRICT\n有传播则拒绝回收", fillcolor="#FDEBD0", fontcolor="#A04000"];
    revoke -> r1;
    revoke -> r2;
    revoke -> r3;

    // ===== 一级分支：用户权限等级 =====
    userlevel [label="用户权限等级", fillcolor="#1ABC9C", fontcolor=white, fontsize=12];
    root -> userlevel;
    ul1 [label="DBA（老板）\n建用户/建库/建表/授权", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    ul2 [label="RESOURCE（经理）\n建表/建视图/传权限", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    ul3 [label="CONNECT（实习生）\n只能登录，等授权", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    userlevel -> ul1;
    userlevel -> ul2;
    userlevel -> ul3;

    // ===== 一级分支：角色管理 =====
    role [label="角色管理\n（权限的集合）", fillcolor="#F39C12", fontcolor=white, fontsize=12];
    root -> role;
    rl1 [label="CREATE ROLE 角色名", fillcolor="#FEF9E7", fontcolor="#B7950B"];
    rl2 [label="GRANT 权限 TO 角色", fillcolor="#FEF9E7", fontcolor="#B7950B"];
    rl3 [label="GRANT 角色 TO 用户", fillcolor="#FEF9E7", fontcolor="#B7950B"];
    rl4 [label="WITH ADMIN OPTION\n传播整个角色", fillcolor="#FEF9E7", fontcolor="#B7950B"];
    rl5 [label="优势：改一处全员生效", fillcolor="#FEF9E7", fontcolor="#B7950B"];
    role -> rl1;
    role -> rl2;
    role -> rl3;
    role -> rl4;
    role -> rl5;

    // ===== 一级分支：易混淆对比 =====
    compare [label="易混淆对比", fillcolor="#34495E", fontcolor=white, fontsize=12];
    root -> compare;
    cp1 [label="GRANT OPTION\n传播具体权限\nvs\nADMIN OPTION\n传播整个角色", fillcolor="#D5D8DC", fontcolor="#2C3E50"];
    cp2 [label="CASCADE\n连坐全收\nvs\nRESTRICT\n有传播就拒", fillcolor="#D5D8DC", fontcolor="#2C3E50"];
    cp3 [label="DBA 全能老板\nRESOURCE 部门经理\nCONNECT 实习生", fillcolor="#D5D8DC", fontcolor="#2C3E50"];
    compare -> cp1;
    compare -> cp2;
    compare -> cp3;
}
