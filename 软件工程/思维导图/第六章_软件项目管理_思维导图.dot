digraph 第六章_软件项目管理 {
    rankdir=LR;
    bgcolor="#FAFBFC";
    node [shape=box, style="rounded,filled", fontname="STHeiti", fontsize=11];
    edge [color="#5B6770", penwidth=1.2];
    splines=ortho;
    nodesep=0.3;
    ranksep=0.6;

    // ===== 根节点 =====
    root [label="第六章\n软件项目管理", fillcolor="#1A5276", fontcolor=white, fontsize=15, shape=box, style="filled,rounded", width=2.2, height=1.2];

    // ===== 核心矛盾 =====
    core [label="核心目标", fillcolor="#2E86C1", fontcolor=white, fontsize=12];
    core_detail [label="按时·按预算·高质量\n完成软件项目", fillcolor="#D6EAF8", fontcolor="#1A5276", fontsize=10];
    root -> core;
    core -> core_detail;

    // ===== 一级分支：进度管理（红-考点） =====
    b1 [label="进度管理★", fillcolor="#E74C3C", fontcolor=white, fontsize=12];
    root -> b1;
    b1_n1 [label="关键路径=最长路径(非最短!)\n决定最短工期·松弛时间=0", fillcolor="#FADBD8", fontcolor="#922B21"];
    b1_n2 [label="PERT期望=(乐+4可+悲)/6\n标准差=(悲-乐)/6", fillcolor="#FADBD8", fontcolor="#922B21"];
    b1 -> b1_n1;
    b1 -> b1_n2;

    // ===== 一级分支：风险管理（青-概念） =====
    b2 [label="风险管理", fillcolor="#1ABC9C", fontcolor=white, fontsize=12];
    root -> b2;
    b2_n1 [label="四步:识别→估计→驾驭→监控", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    b2_n2 [label="策略:避转减接\n保险=转移·换方案=规避", fillcolor="#D1F2EB", fontcolor="#0E6655"];
    b2 -> b2_n1;
    b2 -> b2_n2;

    // ===== 一级分支：质量保证（绿-方法） =====
    b3 [label="质量保证SQA", fillcolor="#27AE60", fontcolor=white, fontsize=12];
    root -> b3;
    b3_n1 [label="技正走审\n走查=非正式·审查=正式", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    b3_n2 [label="走查松·审查严", fillcolor="#D5F5E3", fontcolor="#1E8449"];
    b3 -> b3_n1;
    b3 -> b3_n2;

    // ===== 一级分支：配置管理（紫） =====
    b4 [label="配置管理SCM", fillcolor="#8E44AD", fontcolor=white, fontsize=12];
    root -> b4;
    b4_n1 [label="项基版变审\n配置项·基线·版本·变更·审计", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    b4_n2 [label="基线=变更基准快照", fillcolor="#E8DAEF", fontcolor="#6C3483"];
    b4 -> b4_n1;
    b4 -> b4_n2;

    // ===== 一级分支：CMM五级（橙-考点） =====
    b5 [label="CMM五级★", fillcolor="#D35400", fontcolor=white, fontsize=12];
    root -> b5;
    b5_n1 [label="初重定管优\n1初始2可重复3已定义", fillcolor="#FDEBD0", fontcolor="#A04000"];
    b5_n2 [label="4已管理(定量)5优化(改进)\n注:CMMI第4级叫量化管理级", fillcolor="#FDEBD0", fontcolor="#A04000"];
    b5 -> b5_n1;
    b5 -> b5_n2;

    // ===== 一级分支：面向对象背景（黄） =====
    b6 [label="面向对象(背景)", fillcolor="#F39C12", fontcolor=white, fontsize=12];
    root -> b6;
    b6_n1 [label="类·对象·封装·继承·多态", fillcolor="#FEF9E7", fontcolor="#B7950B"];
    b6_n2 [label="UML:类图·用例图·顺序图等", fillcolor="#FEF9E7", fontcolor="#B7950B"];
    b6 -> b6_n1;
    b6 -> b6_n2;

    // ===== 一级分支：易混淆对比 =====
    compare [label="易混淆对比", fillcolor="#34495E", fontcolor=white, fontsize=12];
    root -> compare;
    cp1 [label="关键路径=最长(非最短!)\n决定最短工期", fillcolor="#D5D8DC", fontcolor="#2C3E50"];
    cp2 [label="CMM第4级:已管理级(CMM叫法)\n量化管理级(CMMI叫法)", fillcolor="#D5D8DC", fontcolor="#2C3E50"];
    compare -> cp1;
    compare -> cp2;
}
